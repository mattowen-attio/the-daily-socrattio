# ---- Slack (the LAST thing to add — needs the bot token) ----
SLACK_BOT_TOKEN=xoxb-...          # bot token: chat:write, users:read, im:write, mpim:write, reactions:write
SLACK_SIGNING_SECRET=...          # App Credentials → Signing Secret (verifies requests)
SLACK_CHANNEL_ID=C0XXXXXXX        # the #the-daily-socrattio channel ID

# ---- Claude (judging) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Upstash Redis (private answer + game state store) ----
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ---- Cron protection ----
CRON_SECRET=generate-a-long-random-string   # Vercel sends this as a Bearer token to cron endpoints

# ---- Site (so the read API allows your Pages origin) ----
SITE_ORIGIN=https://YOURNAME.github.io      # used for CORS on /api/state
